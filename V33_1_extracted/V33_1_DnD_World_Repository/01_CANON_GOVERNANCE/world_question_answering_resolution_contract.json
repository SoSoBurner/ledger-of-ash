      "specific locality",
      "route cluster or corridor",
      "polity or macroregion",
      "world or cosmology scope"
    ],
    "inheritance_rule": "If a target packet is incomplete, inherit upward from parent locality, then parent polity, then world baseline, but never overwrite stronger local canon.",
    "alias_resolution_required": true,
    "minimum_resolved_identity_fields": [
      "canonical_name",
      "object_type",
      "parent_region",
      "canonical_path_or_packet_family"
    ]
  },
