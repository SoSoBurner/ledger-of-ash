  "canon_sensitivity_rules": {
    "must_preserve_core_world_truths": [
      "The world is shaped by Doomsday and its ongoing aftermath.",
      "Polities have distinct governance, value systems, and material constraints.",
      "Gods, religions, and supernatural phenomena are setting-structural, not ornamental.",
      "Local answers must remain compatible with broader cosmology, chronology, and polity structure.",
      "Trade, law, demography, and conflict should be treated as interconnected rather than isolated facts."
    ],
    "must_not_do": [
      "Invent new major powers, gods, wars, or metaphysical laws to fill a gap.",
      "Present local custom as world-universal unless supported.",
      "Collapse conflicting evidence into certainty without reporting reconciliation or uncertainty.",
      "Use runtime or session artifacts as stronger authority than canon baseline."
    ]
  },
  "recommended_runtime_algorithm": [
    "1. Resolve the target entity and scope.",
    "2. Classify the question into one or more question families.",
    "3. Load the most local packet family first.",
    "4. Pull supporting parent polity and world-baseline evidence.",
    "5. Apply source hierarchy and truth zone preference.",
    "6. Reconcile contradictions only through registered reconciliation logic or conservative inference.",
    "7. Return structured answer objects with explicit status and unresolved edges.",
    "8. For broad overviews, emit all eleven families in required order."
  ],
