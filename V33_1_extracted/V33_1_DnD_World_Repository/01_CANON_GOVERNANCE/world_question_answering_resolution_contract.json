  "file_name": "world_question_answering_resolution_contract.json",
  "recommended_repo_path": "01_CANON_GOVERNANCE/world_question_answering_resolution_contract.json",
  "purpose": "Standardize how LLMs and code answer repository-grounded worldsetting questions for places, peoples, polities, factions, religions, routes, conflicts, and hidden truths without inventing unsupported canon.",
  "design_goals": [
    "Route natural-language questions to the correct canon layers and packet families.",
    "Prefer direct canon, then corrected canon, then reconciled canon, then conservative inference.",
    "Return usable answers even when evidence is partial, while exposing uncertainty explicitly.",
    "Prevent omission of required categories when generating inspection packets or direct answers.",
    "Support both machine retrieval and human-readable response composition."
  ],
  "depends_on_existing_contracts": [
    "01_CANON_GOVERNANCE/source_hierarchy.json",
    "01_CANON_GOVERNANCE/truth_layer_model.json",
