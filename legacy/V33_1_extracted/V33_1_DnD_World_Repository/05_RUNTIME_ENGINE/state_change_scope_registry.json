{
  "build_version": "V33_1",
  "scope_rules": [
    {
      "scope": "locality",
      "permitted_change": "conditions, trust, scrutiny, route friction, rumor state",
      "canon_protected_boundaries": [
        "cosmology",
        "pantheon truth",
        "baseline polity identity",
        "major settled geography"
      ],
      "reversible_default": true,
      "requires_escalation_for_continuity": false
    },
    {
      "scope": "route",
      "permitted_change": "inspection intensity, danger posture, closure windows, patrol pressure",
      "canon_protected_boundaries": [
        "route existence absent declared supersession"
      ],
      "reversible_default": true,
      "requires_escalation_for_continuity": false
    },
    {
      "scope": "world",
      "permitted_change": "none without declared escalation",
      "canon_protected_boundaries": [
        "all canon baseline world truths"
      ],
      "reversible_default": false,
      "requires_escalation_for_continuity": true
    }
  ]
}
